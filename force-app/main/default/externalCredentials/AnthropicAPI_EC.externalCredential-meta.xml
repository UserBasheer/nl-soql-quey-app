<?xml version="1.0" encoding="UTF-8"?>
<ExternalCredential xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>AnthropicAPI EC</label>
    <authenticationProtocol>NoAuthentication</authenticationProtocol>
    <!--
      Minimal shell External Credential. This exists ONLY to make the
      AnthropicAPI Named Credential a valid, linkable authenticated callout
      route in the org. It intentionally:
        - configures NO principal that injects an x-api-key (or any other)
          header,
        - stores NO API key / secret / parameter values,
        - performs NO authentication of its own.

      ClaudeTranslationProvider (Apex) sets the x-api-key header itself from
      AnthropicSettings__c.ApiKey__c. Do not add externalCredentialParameters
      or principals with header-injecting parameters to this file.
    -->
    <principals>
        <principalName>AnthropicApiPrincipal</principalName>
        <principalType>NamedPrincipal</principalType>
        <sequenceNumber>1</sequenceNumber>
    </principals>
</ExternalCredential>
