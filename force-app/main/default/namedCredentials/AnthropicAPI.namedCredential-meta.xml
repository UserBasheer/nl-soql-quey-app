<?xml version="1.0" encoding="UTF-8"?>
<NamedCredential xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>AnthropicAPI</label>
    <endpoint>https://api.anthropic.com</endpoint>
    <principalType>NamedUser</principalType>
    <generateAuthorizationHeader>false</generateAuthorizationHeader>
    <!--
      Configure auth in the org (External Credential + the x-api-key header)
      after deploy. The API key is NEVER stored in source. Orgs using Einstein
      can ignore this entirely.
    -->
</NamedCredential>
