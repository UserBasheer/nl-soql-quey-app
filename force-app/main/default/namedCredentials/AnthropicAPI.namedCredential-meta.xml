<?xml version="1.0" encoding="UTF-8"?>
<NamedCredential xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>AnthropicAPI</label>
    <endpoint>https://api.anthropic.com</endpoint>
    <principalType>NamedUser</principalType>
    <generateAuthorizationHeader>false</generateAuthorizationHeader>
    <externalCredential>AnthropicAPI_EC</externalCredential>
    <!--
      Linked to the AnthropicAPI_EC External Credential shell purely so this
      Named Credential is a permitted/linkable authenticated callout route.
      That External Credential injects NO headers and stores NO secrets.

      ClaudeTranslationProvider (Apex) sets the x-api-key header itself from
      AnthropicSettings__c.ApiKey__c. The API key is NEVER stored in source.
      Orgs using Einstein can ignore this entirely.
    -->
</NamedCredential>
